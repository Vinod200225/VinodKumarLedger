# Copy to .env and fill in. NEVER commit .env.

# --- Sheet IDs (from the Google Sheet URL between /d/ and /edit) ---
VITE_PUBLIC_SHEET_ID=
VITE_REAL_SHEET_ID=

# --- API keys for READ access (Google Cloud Console → Credentials → API key, restrict to Sheets API) ---
VITE_PUBLIC_SHEET_API_KEY=
VITE_REAL_SHEET_API_KEY=

# --- Apps Script Web App URLs for WRITE access ---
# Deploy apps-script/Code.gs as a Web App ("Execute as me", "Anyone with the link").
# Use the SAME script bound to BOTH sheets, OR deploy two separate scripts.
VITE_PUBLIC_SHEETS_WEBHOOK=
VITE_REAL_SHEETS_WEBHOOK=

# --- Shared secret between this app and the Apps Script ---
# Any random string. Must match WEBHOOK_SECRET inside Code.gs.
VITE_SHEETS_WEBHOOK_SECRET=

# --- Password hashes (SHA-256 hex of your chosen passwords) ---
# Generate by pasting the snippet in CLAUDE.md into a browser console.
VITE_PUBLIC_PASSWORD_HASH=
VITE_REAL_PASSWORD_HASH=
